# -----------------------------------------------------------------------------
# InstaManager Backend Environment Template
# Copy this file to backend/.env and adjust values as needed.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# AI Providers
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
ANTIGRAVITY_API_KEY=
OPENAI_CODEX_ACCESS_TOKEN=
OPENAI_CODEX_REFRESH_TOKEN=
OPENAI_CODEX_EXPIRES_AT=
OPENAI_CODEX_ACCOUNT_ID=
OPENAI_CODEX_API_BASE_URL=https://api.openai.com/v1
OPENAI_CODEX_OAUTH_TIMEOUT_SECONDS=30
OPENAI_CODEX_WHAM_TIMEOUT_SECONDS=20
CLAUDE_CODE_ACCESS_TOKEN=
CLAUDE_CODE_REFRESH_TOKEN=
CLAUDE_CODE_EXPIRES_AT=
CLAUDE_CODE_OAUTH_TIMEOUT_SECONDS=30
CLAUDE_CODE_API_TIMEOUT_SECONDS=45
CLAUDE_CODE_MAX_TOKENS=8096
CLAUDE_CODE_ANTHROPIC_VERSION=2023-06-01
# Comma-separated beta flags when needed (optional)
# CLAUDE_CODE_ANTHROPIC_BETA=prompt-caching-2024-07-31,oauth-2025-04-20

# -----------------------------------------------------------------------------
# Operator Copilot / Smart Engagement Flags
# -----------------------------------------------------------------------------
# 1=true/on, 0=false/off
ENABLE_OPERATOR_COPILOT=1
SMART_ENGAGEMENT_EXECUTION_ENABLED=true
ENABLE_PROVIDER_OPENAI_CODEX=true
ENABLE_PROVIDER_CLAUDE_CODE=true

# -----------------------------------------------------------------------------
# Audit Log Paths (optional)
# -----------------------------------------------------------------------------
# SMART_ENGAGEMENT_AUDIT_LOG_PATH=backend/sessions/smart_engagement_audit.log
# OPERATOR_COPILOT_AUDIT_LOG_PATH=backend/sessions/operator_copilot_audit.log

# -----------------------------------------------------------------------------
# Persistence Runtime Selection
# -----------------------------------------------------------------------------
# Supported: memory (default), sqlite, sql
PERSISTENCE_BACKEND=memory
# Required for encrypted durable secret storage (LLM keys + OAuth refresh tokens)
ENCRYPTION_KEY=

# Prefer explicit SQLAlchemy URL for SQL/production mode:
#   sqlite+pysqlite:////absolute/path/to/persistence.sqlite3
#   postgresql+psycopg://user:password@host:5432/dbname
PERSISTENCE_DATABASE_URL=

# SQLite fallback path if DATABASE_URL is empty and backend=sqlite/sql
PERSISTENCE_SQLITE_PATH=

# -----------------------------------------------------------------------------
# Persistence Connection Tuning (optional)
# -----------------------------------------------------------------------------
# Used for non-SQLite pool
PERSISTENCE_POOL_SIZE=10
PERSISTENCE_MAX_OVERFLOW=20
PERSISTENCE_POOL_TIMEOUT_SECONDS=30

# Used for SQLite lock wait
PERSISTENCE_SQLITE_BUSY_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Requests per minute per client IP (0 = disabled)
APP_RATE_LIMIT_RPM=120
# Extra burst allowance above RPM
APP_RATE_LIMIT_BURST=20
# Comma-separated paths exempt from rate limiting
# APP_RATE_LIMIT_EXCLUDE_PATHS=/health,/docs,/openapi.json,/redoc

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Dashboard authentication (optional).
# When all three are set, the frontend /login page enforces a password gate.
# Tokens are stateless JWTs signed with AUTH_SECRET, valid for 24 hours.
# ENABLE_DASHBOARD_AUTH=true
# ADMIN_PASSWORD=your-strong-password-here
# AUTH_SECRET=random-secret-used-to-sign-jwt-tokens

# Backend API key (optional).
# When set, every API request must carry the header: X-API-Key: <value>
# Paths exempt from the check: /health, /docs, /openapi.json, /redoc,
#   /api/dashboard/auth/status, /api/dashboard/auth/login
# Configure the matching key from Settings > Connection in the frontend.
# API_KEY=your-backend-api-key-here

# -----------------------------------------------------------------------------
# HTTP Runtime
# -----------------------------------------------------------------------------
# Comma-separated list. Leave empty for same-origin deployments behind a reverse proxy.
APP_CORS_ORIGINS=
APP_CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# Include X-API-Key if API_KEY is configured
APP_CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,X-Requested-With,X-API-Key
APP_CORS_ALLOW_CREDENTIALS=true
APP_REQUEST_LOGGING_ENABLED=true
APP_UVICORN_RELOAD=false

# -----------------------------------------------------------------------------
# LangGraph Checkpointer (Long-Term Memory for thread state)
# -----------------------------------------------------------------------------
# memory (default): in-process only
# sqlite: durable thread checkpoints across process restart
LANGGRAPH_CHECKPOINTER_BACKEND=memory
# LANGGRAPH_CHECKPOINTER_SQLITE_PATH=backend/sessions/langgraph_checkpoints.sqlite3
